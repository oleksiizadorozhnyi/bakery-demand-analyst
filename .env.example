# Copy to .env and fill in values.

# --- Database ---
DB_PATH=bakery.db
SEED_DAYS=90
SEED_RANDOM_STATE=42

# --- Seed mode ---
# SEED_MODE=synthetic          # default; fully synthetic, no external data needed
# SEED_MODE=semi_synthetic     # real bakery CSV + Open-Meteo Paris weather
# BAKERY_CSV_PATH=data/raw/bakery_sales.csv
# WEATHER_CACHE_PATH=data/raw/paris_weather.csv

# --- API server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Failure simulation (all off by default) ---
FAILURE_ENABLED=false
ERROR_500_PROBABILITY=0.0
DELAY_PROBABILITY=0.0
DELAY_SECONDS=5.0
PARTIAL_RECORD_PROBABILITY=0.0

# --- History windows ---
MAIN_WINDOW_DAYS=28
RECENT_WINDOW_DAYS=14

# --- LLM ---
CLAUDE_API_KEY=sk-ant-...
USE_MOCK_LLM=false
CLAUDE_MODEL=claude-sonnet-4-6
